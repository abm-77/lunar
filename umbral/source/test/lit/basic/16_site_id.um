# RUN: %uc %s --dump-ir | %FileCheck %s

# @site_id() as a default parameter — each call site gets a unique u32 ID.
# The __um_sites global table records one entry per call site.

const log := fn(site: u32 = @site_id()) -> u32 {
  return site;
}

const main := fn() -> void {
  const a := log();
  const b := log();
  const c := log();
}

# Three call sites → three site entries.
# CHECK: @__um_sites = constant [3 x { ptr, i32, i32 }]
# CHECK: @__um_sites_count = constant i32 3

# Each call passes a distinct consecutive site ID.
# CHECK: define i32 @main
# CHECK: call {{.*}}log{{.*}}(i32 0)
# CHECK: call {{.*}}log{{.*}}(i32 1)
# CHECK: call {{.*}}log{{.*}}(i32 2)
