# RUN: not %uc %s
# CHECK: write-only shader field

const vec2 := vec<f32, 2>;
const vec4 := vec<f32, 4>;

@shader_pod const SpriteVertex := struct {
  @location(0) pos: vec2,
};

@shader_pod const SpriteVsOut := struct {
  @builtin(position) clip: vec4,
};

@shader const SpriteShader := struct {
  @vs_in  vin:  SpriteVertex,
  @vs_out vout: SpriteVsOut,
};

impl SpriteShader {
  @stage(vertex)
  const vert := fn(&mut self) -> void {
    # reading self.vout.clip is a write-only field access — error
    const _ := self.vout.clip;
  };
}
