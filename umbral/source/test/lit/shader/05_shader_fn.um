# RUN: %uc %s --dump-shader-mlir 2>/dev/null | %FileCheck %s

# helper emitted as func.func without stage attr, called from fragment stage
# CHECK: func.func private @SpriteShader_sample_tex
# CHECK-NOT: stage =
# CHECK-SAME: shader_type = "SpriteShader"

# CHECK: func.func private @SpriteShader_vert
# CHECK-SAME: stage = "vertex"

# CHECK: func.func private @SpriteShader_frag
# CHECK-SAME: stage = "fragment"
# CHECK: call @SpriteShader_sample_tex

const vec2 := vec<f32, 2>;
const vec4 := vec<f32, 4>;

@shader_pod const SpriteVertex := struct {
  @location(0) pos: vec2,
};

@shader_pod const SpriteVsOut := struct {
  @builtin(position) clip: vec4,
  @location(0)       uv:   vec2,
};

@shader_pod const SpriteFsOut := struct {
  @location(0) color: vec4,
};

@shader const SpriteShader := struct {
  @vs_in   vin:  SpriteVertex,
  @vs_out  vout: SpriteVsOut,
  @fs_in   fin:  SpriteVsOut,
  @fs_out  fout: SpriteFsOut,
};

impl SpriteShader {
  @shader_fn
  const sample_tex := fn(&self) -> void {
    const col := @sample(@texture2d(0), @sampler(0), self.fin.uv);
    self.fout.color = col;
  };

  @stage(vertex)
  const vert := fn(&mut self) -> void {
    self.vout.clip = vec4(self.vin.pos.x, self.vin.pos.y, 0.0, 1.0);
    self.vout.uv   = vec2(self.vin.pos.x, self.vin.pos.y);
  };

  @stage(fragment)
  const frag := fn(&mut self) -> void {
    self.sample_tex();
  };
}
