# RUN: %uc %s -g --dump-ir | %FileCheck %s

# struct-typed locals must produce a DICompositeType with member entries
# for each field.

const Point := struct {
  x: i32,
  y: i32,
}

const main := fn() -> void {
  const p := Point { x = 1, y = 2 };
}

# CHECK: #dbg_declare
# CHECK: !DICompositeType(tag: DW_TAG_structure_type
# CHECK: !DIDerivedType(tag: DW_TAG_member, name: "x"
# CHECK: !DIDerivedType(tag: DW_TAG_member, name: "y"
