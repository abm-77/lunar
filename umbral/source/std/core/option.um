@pub const Option<T: type> := struct {
  has_value: bool,
  value: T,
}

impl Option<T> {
  const some := fn(v: T) -> Option<T> {
    return Option<T> {
        has_value = true,
        value = v,
    };
  }

  const none := fn() -> Option<T> {
    return Option<T> {
        has_value = false,
    };
  }

  const unwrap := fn(&self) -> &T {
    return self.value;
  }

  const unwrap_mut := fn(&mut self) -> &mut T {
    return self.value;
  }
}
