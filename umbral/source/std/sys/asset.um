@pub const AssetId := u64;
@pub const ASSET_NULL: AssetId = 0;

@pub @extern const rt_assets_init   : fn(&u8, u64) -> void;
@pub @extern const rt_asset_load    : fn(AssetId) -> []u8;
@pub @extern const rt_asset_release : fn(AssetId) -> void;

@pub const init := fn(pack_path: []u8) -> void {
    rt_assets_init(pack_path.ptr, pack_path.len);
}
