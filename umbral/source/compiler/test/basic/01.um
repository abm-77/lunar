# RUN: %uc %s


# for global variables, type is NOT optional

# global constant variable
const a: i32 = 10

# global mutable variable
var b: i32 = 10

# enum
const Color : type = enum {
  Red,
  Green,
  Blue,
};

# type infer
const Color2 := enum {
  Red,
  Green,
  Blue,
};

const is_red := fn (color: Color) -> bool {
  return color == Color::Red;
}

# struct decl
const Quad: type = struct {
  x: u32,
  y: u32,
  w: u32,
  h: u32,
}

impl Quad {
  # constant instance method
  # const q: Quad = ...;
  # q.area()
  const area := fn (&self) -> u32 {
    return self.w * self.h;
  }

  # instance method
  # const q: Quad = ...;
  # q.set_pos(10, 10)
  const set_pos := fn (&mut self, newX: u32, newY: u32) -> void  {
    self.x = newX;
    self.y = newY;
  }

  # static method
  # const q1: Quad = ...;
  # const q2: Quad = ...;
  # const biggest = Quad::max(q1, q2);
  const max := fn (q1: Quad, q2: Quad) -> Quad {
    if (q1.area() > q2.area()) {
        return q1;
    }
    else {
        return q2;
     }
  }
};

# infer type
const Quad2 := struct {
  x: u32,
  y: u32,
  w: u32,
  h: u32,
}


# generic struct decl
const List<T: type, N: i32> : type = struct {
  data: [N]T,
}

impl List<T, N> {
  const sum := fn (&self) -> T {
    var s := 0;
    for (var i := 0; i < N; i += 1) {
      s += self.data[i];
    }
    return s;
  }
} 

# infer type
const List2<T: type, N: i32> := struct {
  data: [N]T,
}


# function decl
# define a function value and bind it to an immutable name
# add is of type fn (i32, i32) -> i32
const add: fn (i32, i32) -> i32 = fn (a: i32, b: i32) -> i32 {
  const sum: i32 = a + b;
  return sum;
}

# infer type
const add2 := fn (a: i32, b: i32) -> i32 {
  # inside functions, type inference is allowed
  const sum := a + b;
  return sum;
}

# generic function
const add_gen<T: type>: fn(T,T) -> T = fn (a: T, b: T) -> T {
  const sum: T = a + b;
  return sum;
}

# infer type
const add_gen2<T: type> := fn (a: T, b: T) -> T {
  const sum := a + b;
  return sum;
}

# mutable variable that holds a function pointer
# a function type is of the form fn(T1,...,Tn) -> R
# a function literal is fn (var1: T1, ...) -> R { ... }
var fp: fn (i32) -> i32;

# fn type as a first-class value (type bound to a name)
# BinaryFn is of type `type`, its value is the fn type fn(i32, i32) -> i32
const BinaryFn: type = fn(i32, i32) -> i32

# infer type
const BinaryFn2 := fn(i32, i32) -> i32


