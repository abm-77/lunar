# RUN: %uc %s --root %S/../../../std -o %t && %t | %FileCheck %s
# compound assignment operators: +=, -=, *=, /=

import sys.io.fmt => fmt;

const main := fn() -> i32 {
  var x: i32 = 10;
  x += 5;
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(x) });

  x -= 3;
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(x) });

  x *= 4;
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(x) });

  x /= 6;
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(x) });

  # compound on floats
  var f: f64 = 1.0;
  f += 0.5;
  f *= 4.0;
  const fi := @as(f, i64);
  fmt::println("{}", []fmt::Arg{ fmt::arg_i64(fi) });

  return 0;
}

# CHECK: 15
# CHECK: 12
# CHECK: 48
# CHECK: 8
# CHECK: 6
