# RUN: %uc %s --root %S/../../../std -o %t && %t | %FileCheck %s
# runtime verification of if/else chains and complex control flow

import sys.io.fmt => fmt;

const classify := fn(x: i32) -> i32 {
  if (x < 0) {
    return 0;
  } else if (x == 0) {
    return 1;
  } else if (x < 10) {
    return 2;
  } else if (x < 100) {
    return 3;
  } else {
    return 4;
  }
}

const fib := fn(n: i32) -> i32 {
  if (n <= 1) { return n; }
  var a: i32 = 0;
  var b: i32 = 1;
  for (var i: i32 = 2; i <= n; i += 1) {
    const c := a + b;
    a = b;
    b = c;
  }
  return b;
}

const main := fn() -> i32 {
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(classify(-5)) });
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(classify(0)) });
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(classify(7)) });
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(classify(42)) });
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(classify(999)) });
  fmt::println("{}", []fmt::Arg{ fmt::arg_i32(fib(10)) });
  return 0;
}

# CHECK: 0
# CHECK: 1
# CHECK: 2
# CHECK: 3
# CHECK: 4
# CHECK: 55
