import sys.core.mem => mem;

@gen const List<T: type, N: u32> :=  {
  @if(N <= 8) {
    struct {
      # stack allocated
      data: [8]T,
      len: u32,
      cap: u32,
    }
  }
  @else {
    struct {
      data: []T,
      len u32,
      cap: u32,
    }
  }
}

impl List<T, N> {
  @gen const make := fn () -> List<T, N> {
    @if(n <= 8) {
      return List<T, N> {
        data = [8]T{},
        len = 0,
        cap = 8,
      }
    }
    @else {
      return List<T, N> {
        data = @as(mem::alloc(T, N), []T),
        len = 0,
        cap = N,
      }
    }
  }

  @gen const push := fn (&mut self, x: T) -> void {
    @if(n <= 8) {
      self.data[self.len] = x;
      self.len++;
    }
    @else {
      self.grow_and_push(x)
    }
  }

  @gen const grow_and_push := fn(&mut self, x: T) -> void {
    @if(N <= 8) {
        return;
    }
    @else {
      if (self.len == self.cap) {
        const new_cap := N * 2;
        const new_data :=  @as(mem::realloc(self.data, T, new_cap), []T);
        self.data = new_data;
        self.data[self.len] = x;
        self.len += 1;
        self.cap = new_cap
      }
      else {
        self.data[self.len] = x;
        self.len += 1;
      }
    }
  }
}

const main := fn () -> i32 {
  var small_list := List<i32, 10>::make();
  var big_list := List<i32, 100>::make();
  return 0;
}
