# RUN: %uc %s

@gen const Array<T: type, N: u32> := {
  @if(N <= 8) {
    struct { data: [8]T, len: u32 }
  }
  @else {
    struct { data: [16]T, len: u32 }
  }
}

impl Array<T, N> {
  @gen const make := fn () -> Array<T, N> {
    @if(N <= 8) {
      return Array<T, N> { data = [8]T{}, len = 0 };
    }
    @else {
      return Array<T, N> { data = [16]T{}, len = 0 };
    }
  }

  @gen const push := fn (&mut self, x: T) -> void {
    self.data[self.len] = x;
    self.len += 1;
  }
}

const main := fn () -> i32 {
  var small := Array<i32, 4>::make();
  var large := Array<i32, 10>::make();
  small.push(1);
  large.push(2);
  return 0;
}
