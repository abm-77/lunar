# RUN: mkdir -p %t.d && %uc %s --sidecar-out %t.d && %ul --dump-ir %t.d/00_sprite.umshaders 2>/dev/null | %FileCheck %s

# vertex stage: SPIR-V triple, void main(), marked vertex
# CHECK: target triple = "spirv64-unknown-vulkan1.2"
# CHECK: define void @main()
# CHECK: "hlsl.shader"="vertex"

# fragment stage: SPIR-V triple, bindless globals, void main(), texture/sampler loads, marked pixel
# CHECK: target triple = "spirv64-unknown-vulkan1.2"
# CHECK: @textures_2d = external global [0 x target("spirv.Image"
# CHECK: @samplers = external global [0 x target("spirv.Sampler"
# CHECK: define void @main()
# CHECK: load target("spirv.Image"
# CHECK: load target("spirv.Sampler"
# CHECK: "hlsl.shader"="pixel"

const vec2 := struct { x: f32, y: f32 };
const vec4 := struct { x: f32, y: f32, z: f32, w: f32 };

@shader_pod const SpriteVertex := struct {
  @location(0) pos: vec2,
  @location(1) uv:  vec2,
};

@shader_pod const SpriteVsOut := struct {
  @builtin(position) clip: vec4,
  @location(0)       uv:   vec2,
};

@shader_pod const SpriteFsOut := struct {
  @location(0) color: vec4,
};

@shader const SpriteShader := struct {
  @vs_in   vin:  SpriteVertex,
  @vs_out  vout: SpriteVsOut,
  @fs_in   fin:  SpriteVsOut,
  @fs_out  fout: SpriteFsOut,
};

impl SpriteShader {
  @stage(vertex)
  const vert := fn(&mut self) -> void {
    self.vout.clip = vec4(self.vin.pos.x, self.vin.pos.y, 0.0, 1.0);
    self.vout.uv   = vec2(self.vin.uv.x, self.vin.uv.y);
  };

  @stage(fragment)
  const frag := fn(&mut self) -> void {
    const tex  := @texture2d(0);
    const samp := @sampler(0);
    const col  := @sample(tex, samp, self.fin.uv);
    self.fout.color = col;
  };
}
